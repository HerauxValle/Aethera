export AETHERA_SURFACE_C="#132433"
export AETHERA_SURFACE_CH="#1B3041"
export AETHERA_SURFACE_C_ALPHA="#E1132433"   # #AA=88% opacity
export AETHERA_PRIMARY="#48B9D1"
export AETHERA_ON_PRIMARY="#042A35"
export AETHERA_PRIMARY_C="#0D6B85"
export AETHERA_SECONDARY_C="#1A3545"
export AETHERA_TEXT="#E4EFF5"
export AETHERA_TEXT_MUTED="#7DBACE"
export AETHERA_OUTLINE="#2E5566"
export AETHERA_OUTLINE_V="#1A3040"
